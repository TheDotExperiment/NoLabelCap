# Copy this file to .env and fill in real values. Never commit .env.

# Flask
FLASK_SECRET_KEY=change-me-to-a-long-random-string
FLASK_ENV=production
PORT=5000

# Admin dashboard login (kiosk/admin use only — see README for locking this to LAN)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Stripe (business account) — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
# Optional, only needed if you set up a webhook (see README) — leave blank otherwise
STRIPE_WEBHOOK_SECRET=

# Public base URL Stripe should redirect back to after checkout.
# This must be reachable by the guest's phone, e.g. the Pi's LAN splash address
# or a tunnel URL (Cloudflare Tunnel / ngrok) if you want off-network reachability.
PUBLIC_BASE_URL=http://192.168.50.1:5000

# Venue / network identity
VENUE_NAME=nosplash.dog

# nodogsplash / RaspAP integration
NDS_ENABLE_LIVE_GRANT=false
NDSCTL_PATH=/usr/bin/ndsctl
